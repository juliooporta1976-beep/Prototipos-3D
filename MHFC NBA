                document.getElementById('valAchilles').innerText = val > 70 ? (currentLang === 'es' ? "¡ALERTA CRÍTICA!" : "CRITICAL ALERT!") : (currentLang === 'es' ? "Bajo" : "Normal");
                document.getElementById('valAchilles').style.color = val > 70 ? 'var(--neon-red)' : 'var(--text-muted)';
            } else if (type === 'ICC') {
                const val = document.getElementById('sliderICC').value;
