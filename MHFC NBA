                document.getElementById('valEntropico').innerText = (1 + (100 - val) * 0.05).toFixed(2);
                document.getElementById('valFFE').innerText = (1 + (100 - val) * 0.05).toFixed(2);
            }
        }

        // Web Audio synthesized sounds (100% offline) using OscillatorNode
        function initAudio() {
            try {
                audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                
                // Continuous telemetry ambient sound
                ambientOscillator = audioCtx.createOscillator();
                const gainNode = audioCtx.createGain();

                ambientOscillator.type = 'sawtooth';
                ambientOscillator.frequency.value = 55; // Sub-bass hum
                gainNode.gain.value = 0.005; // Extremely subtle

                // Filter out harsh high mids for cozy movie-like feel
                const biquadFilter = audioCtx.createBiquadFilter();
                biquadFilter.type = "lowpass";
                biquadFilter.frequency.value = 150;

                ambientOscillator.connect(biquadFilter);
                biquadFilter.connect(gainNode);
                gainNode.connect(audioCtx.destination);
                
                ambientOscillator.start();
                isAudioPlaying = true;
            } catch (e) {
                console.warn("Web Audio API not supported on this browser.");
            }
        }

        function toggleAudio() {
            if (!audioCtx) {
                initAudio();
                return;
            }

            if (isAudioPlaying) {
                audioCtx.suspend();
                isAudioPlaying = false;
            } else {
                audioCtx.resume();
                isAudioPlaying = true;
                playLocalBeep(880, 0.08);
            }
        }

        function playLocalBeep(freq, duration) {
            if (!audioCtx) return;
            try {
                const osc = audioCtx.createOscillator();
                const gain = audioCtx.createGain();

                osc.type = 'sine';
                osc.frequency.value = freq;
                gain.gain.setValueAtTime(0.04, audioCtx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.0001, audioCtx.currentTime + duration);

                osc.connect(gain);
                gain.connect(audioCtx.destination);
                osc.start();
                osc.stop(audioCtx.currentTime + duration);
            } catch (err) {}
        }

        function setOpMode(mode) {
            currentMode = mode;
            document.querySelectorAll('.hud-mode-indicator').forEach(ind => {
                ind.classList.remove('active');
            });

            if (mode === 'activo') {
                document.getElementById('modeActivo').classList.add('active');
                players.forEach(p => p.color = '#00f3ff');
            } else if (mode === 'recup') {
                document.getElementById('modeRecup').classList.add('active');
                players.forEach(p => p.color = '#39ff14');
            } else if (mode === 'sim') {
                document.getElementById('modeSim').classList.add('active');
                players.forEach(p => p.color = '#ffaa00');
            } else if (mode === 'emerg') {
                document.getElementById('modeEmerg').classList.add('active');
                players.forEach(p => p.color = '#ff3131');
            }

            playLocalBeep(1000, 0.05);
        }

        // Initialize script logic
        render();
        renderGraph();
