        // 3D Rendering & State variables
        let isSimulating = true;
        let isAudioPlaying = false;
        let audioCtx = null;
        let ambientOscillator = null;

        // Custom High-Performance 3D Grid & Node System
        const canvas = document.getElementById('canvas3d');
        const ctx = canvas.getContext('2d');

        let width = canvas.width = canvas.offsetWidth;
        let height = canvas.height = canvas.offsetHeight;

        window.addEventListener('resize', () => {
            width = canvas.width = canvas.offsetWidth;
            height = canvas.height = canvas.offsetHeight;
        });

        // Interactive mouse rotation and pan math constants
        let rotationX = 0.5;
        let rotationY = 0.6;
        let zoom = 1.0;
        let isDragging = false;
        let prevMouseX = 0;
        let prevMouseY = 0;

        canvas.addEventListener('mousedown', (e) => {
            isDragging = true;
            prevMouseX = e.clientX;
            prevMouseY = e.clientY;
        });

        canvas.addEventListener('mousemove', (e) => {
            if (!isDragging) return;
            const deltaX = e.clientX - prevMouseX;
            const deltaY = e.clientY - prevMouseY;
            rotationY += deltaX * 0.01;
            rotationX = Math.max(-0.5, Math.min(1.2, rotationX + deltaY * 0.01));
            prevMouseX = e.clientX;
            prevMouseY = e.clientY;
        });

        window.addEventListener('mouseup', () => {
            isDragging = false;
        });

        canvas.addEventListener('wheel', (e) => {
            zoom = Math.max(0.4, Math.min(2.5, zoom - e.deltaY * 0.001));
            e.preventDefault();
        }, {passive: false});

        // Simulated Swarm AI Nodes (Players)
        const players = [
            { id: 1, x: -150, z: -80, y: 0, vx: 1, vz: 0.8, color: '#00f3ff', label: "PG (Nodo 1)" },
            { id: 2, x: 100, z: -120, y: 0, vx: -0.7, vz: 1.2, color: '#00f3ff', label: "SG (Nodo 2)" },
            { id: 3, x: -60, z: 80, y: 0, vx: 1.4, vz: -0.5, color: '#39ff14', label: "SF (Nodo 3)" },
            { id: 4, x: 130, z: 90, y: 0, vx: -1.0, vz: -1.1, color: '#00f3ff', label: "PF (Nodo 4)" },
            { id: 5, x: 5, z: 10, y: 0, vx: 0.5, vz: -0.4, color: '#39ff14', label: "C (Nodo 5)" }
        ];

        let playPhase = 0;
        let currentMode = 'activo';

        function project3d(x, y, z) {
            // Basic rotation math around Y axis
            let cosY = Math.cos(rotationY);
            let sinY = Math.sin(rotationY);
            let xRot = x * cosY - z * sinY;
            let zRot = x * sinY + z * cosY;

            // Rotation math around X axis
            let cosX = Math.cos(rotationX);
            let sinX = Math.sin(rotationX);
            let yRot = y * cosX - zRot * sinX;
            let finalZ = y * sinX + zRot * cosX;

            // Perspective factor based on calculated depth
            let perspectiveFactor = 500 / (500 + finalZ * zoom);
            let screenX = width / 2 + xRot * zoom * perspectiveFactor;
            let screenY = height / 2 + yRot * zoom * perspectiveFactor + 50;

            return { x: screenX, y: screenY, depth: finalZ, scale: perspectiveFactor };
        }

        // Draw tactical court grids
        function drawCourt3d() {
            ctx.strokeStyle = 'rgba(0, 243, 255, 0.15)';
            ctx.lineWidth = 1.2;

            const gridLines = 16;
            const courtLength = 400;
            const courtWidth = 250;

            // Draw court floor grid
            for(let i = 0; i <= gridLines; i++) {
                let x = -courtLength/2 + (courtLength/gridLines) * i;
                let pStart = project3d(x, 0, -courtWidth/2);
                let pEnd = project3d(x, 0, courtWidth/2);
                ctx.beginPath();
                ctx.moveTo(pStart.x, pStart.y);
                ctx.lineTo(pEnd.x, pEnd.y);
                ctx.stroke();
            }

            for(let j = 0; j <= 8; j++) {
                let z = -courtWidth/2 + (courtWidth/8) * j;
                let pStart = project3d(-courtLength/2, 0, z);
                let pEnd = project3d(courtLength/2, 0, z);
                ctx.beginPath();
                ctx.moveTo(pStart.x, pStart.y);
                ctx.lineTo(pEnd.x, pEnd.y);
                ctx.stroke();
            }

            // Outer tactical glow bounds matches Stealth aesthetics
            ctx.strokeStyle = 'rgba(0, 243, 255, 0.4)';
            ctx.shadowBlur = 15;
            ctx.shadowColor = 'rgba(0, 243, 255, 0.4)';
            ctx.lineWidth = 2;

            const bounds = [
                [-courtLength/2, -courtWidth/2],
                [courtLength/2, -courtWidth/2],
                [courtLength/2, courtWidth/2],
                [-courtLength/2, courtWidth/2]
            ];

            ctx.beginPath();
            let p0 = project3d(bounds[0][0], 0, bounds[0][1]);
            ctx.moveTo(p0.x, p0.y);
            for(let k = 1; k < bounds.length; k++) {
                let pk = project3d(bounds[k][0], 0, bounds[k][1]);
                ctx.lineTo(pk.x, pk.y);
            }
            ctx.closePath();
            ctx.stroke();

            // Clear shadow blur to optimize performance of drawing nodes
            ctx.shadowBlur = 0;
        }

        // Draw synapses connecting swarm nodes (AI Synaptic Web)
        function drawSynapticConnections() {
            ctx.lineWidth = 1.5;
            for(let i = 0; i < players.length; i++) {
                for(let j = i + 1; j < players.length; j++) {
                    let p1 = project3d(players[i].x, players[i].y, players[i].z);
                    let p2 = project3d(players[j].x, players[j].y, players[j].z);

                    // Dynamic color matching tension parameters
                    let averageTension = (players[i].stressFactor + players[j].stressFactor) / 2;
                    let gradient = ctx.createLinearGradient(p1.x, p1.y, p2.x, p2.y);
                    
                    if (averageTension > 0.6) {
                        gradient.addColorStop(0, 'rgba(255, 49, 49, 0.6)');
                        gradient.addColorStop(1, 'rgba(255, 49, 49, 0.1)');
                        ctx.strokeStyle = gradient;
                    } else {
                        gradient.addColorStop(0, 'rgba(0, 243, 255, 0.5)');
                        gradient.addColorStop(1, 'rgba(57, 255, 20, 0.2)');
                        ctx.strokeStyle = gradient;
                    }

                    ctx.beginPath();
                    ctx.moveTo(p1.x, p1.y);
                    ctx.lineTo(p2.x, p2.y);
                    ctx.stroke();

                    // Tiny energy pulse moving down the connections
                    let progress = (Date.now() / 1500 + i * 0.2) % 1.0;
                    let pulseX = p1.x + (p2.x - p1.x) * progress;
                    let pulseY = p1.y + (p2.y - p1.y) * progress;

                    ctx.fillStyle = averageTension > 0.6 ? '#ff3131' : '#00f3ff';
                    ctx.shadowBlur = 10;
                    ctx.shadowColor = ctx.fillStyle;
                    ctx.beginPath();
                    ctx.arc(pulseX, pulseY, 3, 0, Math.PI * 2);
                    ctx.fill();
                    ctx.shadowBlur = 0;
                }
            }
        }

        // Main Animation render loops
        function render() {
            ctx.clearRect(0, 0, width, height);

            // Shaders style cinematic background details
            drawTacticalGridBackground();

            // 1. Draw solid court base structure
            drawCourt3d();

            // 2. Swarm Swarm Swarm AI movement computation
            if (isSimulating) {
                playPhase += 0.01;
                players.forEach((p, idx) => {
                    // Modular physical constraints
                    p.x += p.vx;
                    p.z += p.vz;

                    // Boundary checks
                    if (Math.abs(p.x) > 180) { p.vx *= -1; p.x = Math.sign(p.x) * 180; }
                    if (Math.abs(p.z) > 110) { p.vz *= -1; p.z = Math.sign(p.z) * 110; }

                    // Sinergia de Flujo Táctico cellular noise wave
                    p.y = Math.sin(playPhase + idx) * 15;
                    p.stressFactor = 0.2 + 0.5 * Math.sin(playPhase * 0.5 + idx);
                });
            }

            // 3. Draw synaptic lines
            drawSynapticConnections();

            // 4. Draw Individual player holograms with HUD data
            players.forEach(p => {
                let coords = project3d(p.x, p.y, p.z);
                let scale = coords.scale * 1.5;

                // Player node halo
                ctx.shadowBlur = 15;
                ctx.shadowColor = p.color;
                ctx.fillStyle = p.color;
                ctx.beginPath();
                ctx.arc(coords.x, coords.y, 8 * scale, 0, Math.PI * 2);
                ctx.fill();
                ctx.shadowBlur = 0;

                // Glowing tactical outer ring
                ctx.strokeStyle = 'rgba(255,255,255,0.4)';
                ctx.lineWidth = 1.0;
                ctx.beginPath();
                ctx.arc(coords.x, coords.y, 14 * scale, 0, Math.PI*2);
                ctx.stroke();

                // Draw miniature wireframe biomechanic mannequin next to active player
                ctx.strokeStyle = 'rgba(0, 243, 255, 0.4)';
                ctx.beginPath();
                ctx.moveTo(coords.x, coords.y);
                ctx.lineTo(coords.x, coords.y - 18 * scale); // Spine
                ctx.lineTo(coords.x - 6 * scale, coords.y - 24 * scale); // Hands
                ctx.moveTo(coords.x, coords.y - 18 * scale);
                ctx.lineTo(coords.x + 6 * scale, coords.y - 24 * scale);
                ctx.moveTo(coords.x, coords.y);
                ctx.lineTo(coords.x - 4 * scale, coords.y + 10 * scale); // Legs
                ctx.moveTo(coords.x, coords.y);
                ctx.lineTo(coords.x + 4 * scale, coords.y + 10 * scale);
                ctx.stroke();

                // Interactive HUD tag indicating player role and IFM metrics
                ctx.fillStyle = '#ffffff';
                ctx.font = `bold ${Math.floor(10 * scale)}px var(--font-mono)`;
                ctx.fillText(p.label, coords.x + 16, coords.y + 4);

                ctx.fillStyle = 'rgba(0, 243, 255, 0.8)';
                ctx.font = `${Math.floor(9 * scale)}px var(--font-mono)`;
                ctx.fillText(`IFM: ${Math.floor(p.stressFactor * 100)}%`, coords.x + 16, coords.y + 15);
            });

            // Loop
            requestAnimationFrame(render);
        }

        function drawTacticalGridBackground() {
            // Hexagon subtle patterns or matrix background lines
            ctx.strokeStyle = 'rgba(255, 255, 255, 0.015)';
            ctx.lineWidth = 1;
            const cellSize = 50;
            for(let x = 0; x < width; x += cellSize) {
                ctx.beginPath();
                ctx.moveTo(x, 0);
                ctx.lineTo(x, height);
                ctx.stroke();
            }
            for(let y = 0; y < height; y += cellSize) {
                ctx.beginPath();
                ctx.moveTo(0, y);
                ctx.lineTo(width, y);
                ctx.stroke();
            }
        }

        // Live stats graph updater
        const canvasGraph = document.getElementById('canvasGraph');
        const ctxGraph = canvasGraph.getContext('2d');
        const graphPoints = Array(30).fill(60);

        function renderGraph() {
            const wG = canvasGraph.width = canvasGraph.offsetWidth;
            const hG = canvasGraph.height = canvasGraph.offsetHeight;

            ctxGraph.clearRect(0,0,wG,hG);
            ctxGraph.strokeStyle = '#00f3ff';
            ctxGraph.lineWidth = 1.5;
            ctxGraph.beginPath();

            const step = wG / (graphPoints.length - 1);
            for(let i = 0; i < graphPoints.length; i++) {
                let x = i * step;
                let y = hG - (graphPoints[i] / 100) * (hG - 10) - 5;
                if (i === 0) ctxGraph.moveTo(x, y);
                else ctxGraph.lineTo(x, y);
            }
            ctxGraph.stroke();

            // Gradient fill matching biomimetic styling
            let grad = ctxGraph.createLinearGradient(0,0,0,hG);
            grad.addColorStop(0, 'rgba(0, 243, 255, 0.2)');
            grad.addColorStop(1, 'rgba(0, 243, 255, 0.0)');
            ctxGraph.fillStyle = grad;
            ctxGraph.lineTo(wG, hG);
            ctxGraph.lineTo(0, hG);
            ctxGraph.closePath();
            ctxGraph.fill();

            // Shift and update graph points dynamically
            if (isSimulating) {
                graphPoints.shift();
                let randomFactor = (Math.random() - 0.5) * 6;
                let lastVal = graphPoints[graphPoints.length - 1];
                let newVal = Math.max(20, Math.min(100, lastVal + randomFactor));
                graphPoints.push(newVal);
            }

            setTimeout(renderGraph, 100);
        }

